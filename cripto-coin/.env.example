# Copy this file to .env and add your actual API key
# DO NOT commit .env to git - it contains sensitive information

# Get your API key from: https://www.coinapi.io/
# Preferred: private server-side runtime config used by the Nuxt API proxy
NUXT_CRYPTO_API_KEY=your-api-key-here

# Backward-compatible fallback accepted by nuxt.config.js during migration
# NUXT_PUBLIC_CRYPTO_API_KEY=your-api-key-here
